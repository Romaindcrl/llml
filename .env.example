# Backend LLM : "mock" (deterministe, sans reseau, defaut)
#             | "mlx"   (modele local Apple Silicon, in-process, RECOMMANDE ici)
#             | "ollama" (serveur Ollama local)
M0_BACKEND=mock

# --- Backend MLX (Apple Silicon) ---
# Chemin d'un modele MLX local (dossier avec config.json + tokenizer + safetensors).
# Defaut : models/mlx-3b-4bit (Llama 3.2 3B 4bit). Alternatives presentes : models/mlx/q4-gs64 (1B).
M0_MLX_MODEL_PATH=models/mlx-3b-4bit
# Budget de generation par appel (tokens).
M0_MLX_MAX_TOKENS=512

# --- Backend Ollama (installe ; qwen2.5:7b disponible — meilleur choix agentique) ---
M0_MODEL=qwen2.5:7b
M0_OLLAMA_HOST=http://localhost:11434

# --- Seuils memoire / compaction (pilotables sans toucher au code) ---
M0_MEMORY_CAP=1200          # plafond de memoire texte injectee en contexte
M0_COMPACT_TRIGGER=4000     # seuil de contexte qui declenche la compaction
M0_MIN_RECOVERABLE=800      # ne prune que si au moins ça est recuperable
M0_MAX_CONTEXT=6000         # cible de fenetre
M0_KEEP_RECENT_TURNS=2      # tours recents toujours proteges
M0_MAX_TURNS=20             # bornes de boucle agent (mode tache)

# --- Serveur OpenAI-compatible (scripts/serve.py) ---
M0_SERVE_HOST=127.0.0.1
M0_SERVE_PORT=8000
